# NoteSync Environment Variables Configuration
# Copy this file to '.env' and fill in your values. Do NOT commit the '.env' file.

# Cloudflare Worker Gateway URL
# Example: https://notesync-backend.your-subdomain.workers.dev
CLOUDFLARE_WORKER_URL=https://your-worker-url.workers.dev

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Firebase Config (for verification metadata if needed in client environment config)
FIREBASE_PROJECT_ID=your-firebase-project-id
